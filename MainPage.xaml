<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpotifyPremium.MainPage"
             BackgroundColor="#121212">

    <VerticalStackLayout>
        <!-- Logo triple tap secreto -->
        <Image Source="spotify_logo.png" HeightRequest="80" Margin="20" HorizontalOptions="Center">
            <Image.GestureRecognizers>
                <TapGestureRecognizer NumberOfTapsRequired="3" Tapped="OnTripleTap" />
            </Image.GestureRecognizers>
        </Image>

        <!-- Tabs -->
        <HorizontalStackLayout Spacing="40" HorizontalOptions="Center" Padding="10">
            <Label Text="Inicio" TextColor="#1DB954" FontSize="20" FontAttributes="Bold" />
            <Label Text="Buscar" TextColor="White" FontSize="20" />
            <Label Text="Biblioteca" TextColor="White" FontSize="20" />
        </HorizontalStackLayout>

        <!-- Lista canciones falsas -->
        <CollectionView x:Name="SongsList" HeightRequest="450" Margin="20">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <HorizontalStackLayout Spacing="15" Padding="10">
                        <Image Source="music_note.png" WidthRequest="50" HeightRequest="50" />
                        <VerticalStackLayout>
                            <Label Text="{Binding Title}" TextColor="White" FontSize="18" />
                            <Label Text="{Binding Artist}" TextColor="#B3B3B3" FontSize="14" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Text="Desarrollado por xpe.nettt" TextColor="#666" FontSize="12" HorizontalOptions="Center" Margin="0,20,0,0" />
    </VerticalStackLayout>
</ContentPage>