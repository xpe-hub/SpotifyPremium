<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpotifyPremium.VaultPage"
             BackgroundColor="#121212">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="VAULT xpe.nettt - MODO OCULTO" TextColor="#1DB954" FontSize="26" FontAttributes="Bold" />
        <Button Text="Agregar archivo (se encripta y oculta)" BackgroundColor="#1DB954" Clicked="OnAddFile" />
        <CollectionView x:Name="VaultList" HeightRequest="250" />
        <Button Text="Activar DNS oculto" BackgroundColor="#1DB954" Clicked="OnActivateDns" />
        <Button Text="Desactivar DNS (SIN RASTROS)" BackgroundColor="Red" Clicked="OnDeactivateDns" />
        <Button Text="Salir del Vault" Clicked="OnExit" />
        <Label Text="Desarrollado por xpe.nettt" TextColor="#666" FontSize="12" HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>