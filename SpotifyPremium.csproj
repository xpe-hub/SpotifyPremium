<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net9.0-ios</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>SpotifyPremium</RootNamespace>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Camuflaje Spotify Premium -->
    <DisplayName>Spotify Premium</DisplayName>
    <ApplicationTitle>Spotify Premium</ApplicationTitle>
    <ApplicationId>com.spotify.premium2026</ApplicationId>          <!-- ← esto soluciona el error -->
    <BundleIdentifier>com.spotify.premium2026</BundleIdentifier>

    <!-- iOS + DNS -->
    <MauiEntitlements>Platforms/iOS/Entitlements.plist</MauiEntitlements>
    <RuntimeIdentifier>ios-arm64</RuntimeIdentifier>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" Version="9.0.120" />
    <MauiImage Include="Resources\Images\*" />
  </ItemGroup>

</Project>
