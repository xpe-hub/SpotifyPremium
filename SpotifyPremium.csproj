<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0-ios</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>SpotifyPremium</RootNamespace>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <DisplayName>Spotify Premium</DisplayName>
    <ApplicationTitle>Spotify Premium</ApplicationTitle>
    <BundleIdentifier>com.spotify.premium2026</BundleIdentifier>
    <MauiEntitlements>Platforms/iOS/Entitlements.plist</MauiEntitlements>
  </PropertyGroup>
  <ItemGroup>
    <MauiImage Include="Resources\Images\*" />
  </ItemGroup>
</Project>